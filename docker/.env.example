# =============================================================================
# backuptool -- environment variables
#
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Random secret used to derive all internal encryption keys.
# Generate: openssl rand -hex 32
MASTER_SECRET=change-me-generate-with-openssl-rand-hex-32


# -----------------------------------------------------------------------------
# Server -- optional / has defaults
# -----------------------------------------------------------------------------

# TCP port the server container exposes on the host.
# When using the Caddy proxy profile, set EXPOSE_PORT="" to keep port 3000
# internal (only reachable by Caddy, not directly from the internet).
# Default: 3000
EXPOSE_PORT=3000

# Allowed CORS origin for the web UI.
# Without proxy: http://localhost:3000
# With proxy:    https://backup.example.com
CORS_ORIGIN=http://localhost:3000

# Ed25519 public key (PEM) for license JWT verification.
# Leave empty for community edition (no license enforcement).
LICENSE_PUBLIC_KEY=


# -----------------------------------------------------------------------------
# Proxy / SSL -- only relevant when using --profile proxy
# -----------------------------------------------------------------------------

# All proxy settings (domain, SSL mode, IP allowlist, certs) are configured
# in the web UI under Settings -> Proxy / SSL after first login.
# No environment variables are needed for the proxy itself.


# -----------------------------------------------------------------------------
# Agent -- local dev profile only (docker compose --profile dev up)
# -----------------------------------------------------------------------------

AGENT_SERVER_URL=http://server:3000
AGENT_TOKEN=
AGENT_NAME=local-agent
