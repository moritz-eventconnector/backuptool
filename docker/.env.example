# =============================================================================
# backuptool — environment variables
#
# Copy this file to .env and fill in the required values before running
# docker compose up.
#
#   cp .env.example .env
#
# Lines starting with # are comments. All values are strings unless noted.
# =============================================================================


# -----------------------------------------------------------------------------
# Server — required
# -----------------------------------------------------------------------------

# Random secret used to derive internal encryption keys (AES, HMAC, etc.).
# Must be a long, unpredictable random string.  Never reuse across environments.
# Generate: openssl rand -hex 32
MASTER_SECRET=change-me-generate-with-openssl-rand-hex-32

# Secret used to sign and verify session cookies.
# Must be different from MASTER_SECRET.
# Generate: openssl rand -hex 32
COOKIE_SECRET=change-me-generate-with-openssl-rand-hex-32


# -----------------------------------------------------------------------------
# Server — optional / has defaults
# -----------------------------------------------------------------------------

# TCP port the server listens on inside the container.
# The host-side port is controlled by the `ports` mapping in docker-compose.yml.
# Default: 3000
PORT=3000

# Allowed CORS origin for the web UI.
# Set to the public URL where the UI is served, e.g. https://backup.example.com
# Default: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Ed25519 public key (PEM) used to validate license JWTs.
# The full PEM including header/footer lines, with literal \n newlines:
#   LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VdA...\n-----END PUBLIC KEY-----"
# Leave empty to run without license enforcement (community edition features only).
LICENSE_PUBLIC_KEY=


# -----------------------------------------------------------------------------
# SMTP — optional, enables email notifications
# -----------------------------------------------------------------------------

# SMTP server hostname (e.g. smtp.sendgrid.net, smtp.gmail.com).
SMTP_HOST=

# SMTP server port.  Common values: 587 (STARTTLS), 465 (TLS), 25 (plaintext).
SMTP_PORT=587

# SMTP authentication username.
SMTP_USER=

# SMTP authentication password / API key.
SMTP_PASS=

# From address used for outgoing emails (e.g. backuptool@example.com).
SMTP_FROM=


# -----------------------------------------------------------------------------
# Agent (local dev profile only — docker compose --profile dev up)
# -----------------------------------------------------------------------------

# URL of the backuptool server the agent should connect to.
# When using docker compose on the same host the service name `server` resolves.
AGENT_SERVER_URL=http://server:3000

# Pre-shared token the agent uses to authenticate with the server.
# Must match a token configured in the server's admin UI or config file.
AGENT_TOKEN=

# Display name for this agent shown in the backuptool web UI.
AGENT_NAME=local-agent
